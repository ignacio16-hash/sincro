generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiCredential {
  id        String   @id @default(cuid())
  platform  String   @unique // bsale, paris, falabella, ripley
  config    Json
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockItem {
  id             String    @id @default(cuid())
  sku            String    @unique
  name           String?
  bsaleStock     Int       @default(0)
  bsaleVariantId String?
  parisStock     Int?
  falabellaStock Int?
  ripleyStock    Int?
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SyncLog {
  id        String   @id @default(cuid())
  type      String   // full_sync, webhook, manual
  platform  String   // bsale, paris, falabella, ripley, all
  status    String   // success, error, partial
  message   String?
  details   Json?
  duration  Int?
  createdAt DateTime @default(now())
}

model SyncEvent {
  id          String   @id @default(cuid())
  source      String   // bsale, paris, falabella, ripley
  eventType   String   // stock_change, order
  sku         String
  quantity    Int
  previousQty Int?
  newQty      Int?
  orderId     String?
  rawPayload  Json?
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Authenticated users. PIN is stored hashed (scrypt).
// Roles: "admin" | "vendedor"
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  pinHash   String
  role      String   @default("vendedor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Etiqueta de envío subida manualmente por un admin para un pedido
// (principalmente pedidos de Shopify, donde no hay API de labels como en
// Falabella/Ripley). El admin la sube, admin y vendedor pueden descargarla.
model ShippingLabel {
  id         String   @id @default(cuid())
  platform   String   // "shopify" (por ahora), extensible
  orderId    String
  pdf        Bytes
  mimeType   String   @default("application/pdf")
  filename   String   @default("etiqueta.pdf")
  sizeBytes  Int
  uploadedBy String   // username del admin que la subió
  uploadedAt DateTime @default(now())

  @@unique([platform, orderId])
  @@index([platform])
}

// Singleton row (id="default") with branding for the /login page.
// logoText replaces the word shown instead of "ZARA" on login.
// imageUrl points at the right-hand model photo on login.
model LoginSettings {
  id        String   @id @default("default")
  logoText  String   @default("PARROT")
  // Optional inline SVG markup. If set, replaces logoText on /login.
  // Sanitized server-side (no <script>, no on* handlers, no javascript: URLs).
  logoSvg   String?
  imageUrl  String   @default("https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80")
  updatedAt DateTime @updatedAt
}
